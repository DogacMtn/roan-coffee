---
import '@fontsource-variable/fraunces';
import '@fontsource-variable/inter';
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Roan Coffee Roasters — Small-batch coffee',
	description = 'Roan Coffee Roasters is a neighborhood specialty coffee shop roasting small-batch beans on the corner. Order online, browse the menu, or visit us.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />

		<!-- Open Graph / social -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta name="twitter:card" content="summary_large_image" />
	</head>
	<body class="font-body bg-cream text-espresso antialiased">
		<slot />
	</body>
</html>
