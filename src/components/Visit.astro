---
const hours = [
	{ days: 'Mon – Fri', time: '7:00 – 18:00' },
	{ days: 'Sat – Sun', time: '8:00 – 17:00' },
];

// placeholder contact details
const phoneDisplay = '+1 (503) 555-0118';
const phoneHref = 'tel:+15035550118';
const email = 'hello@roancoffee.com';
---

<section id="visit" class="bg-cream">
	<div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
		<div class="max-w-2xl">
			<p class="text-sm font-semibold uppercase tracking-[0.2em] text-terracotta">
				Find Us
			</p>
			<h2
				class="mt-4 font-display text-4xl font-semibold leading-tight tracking-tight text-espresso sm:text-5xl"
			>
				Come say hello.
			</h2>
			<p class="mt-5 text-lg leading-relaxed text-espresso/80">
				We’re on the corner where Eastside slows down for a minute. Pull up,
				and the first pour-over’s on the house if you mention this page.
			</p>
		</div>

		<div class="relative mt-12">
			<!-- TODO: swap stylized placeholder for a real map (Google Maps/Leaflet) -->
			<div
				class="relative h-[360px] overflow-hidden rounded-2xl bg-cream-dark ring-1 ring-sand md:h-[560px]"
				style="background-image:
					repeating-linear-gradient(to right, var(--color-sand) 0 1px, transparent 1px 72px),
					repeating-linear-gradient(to bottom, var(--color-sand) 0 1px, transparent 1px 72px);"
				aria-hidden="true"
			>
				<!-- diagonal avenue -->
				<div
					class="absolute -left-1/4 top-1/3 h-16 w-[150%] -rotate-12 bg-sand/60"
				>
				</div>

				<!-- Location pin -->
				<div class="absolute inset-0 flex items-center justify-center md:justify-start md:pl-[12%]">
					<div class="relative flex items-center justify-center">
						<span class="absolute h-20 w-20 rounded-full bg-terracotta/10"></span>
						<span class="absolute h-12 w-12 rounded-full bg-terracotta/20"></span>
						<svg
							class="relative h-12 w-12 -translate-y-2 text-terracotta drop-shadow"
							viewBox="0 0 24 24"
							fill="currentColor"
						>
							<path
								d="M12 2c-3.87 0-7 3.13-7 7 0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5z"
							></path>
						</svg>
					</div>
				</div>
			</div>

			<!-- info card, overlaps the map on desktop -->
			<div
				class="relative z-10 mx-auto -mt-20 max-w-md rounded-2xl border border-sand bg-cream p-7 shadow-xl sm:p-8 md:absolute md:right-8 md:top-1/2 md:mx-0 md:mt-0 md:-translate-y-1/2"
			>
				<h3 class="font-display text-2xl font-semibold text-espresso">
					Roan Coffee Roasters
				</h3>
				<p class="mt-2 text-base leading-relaxed text-espresso/80">
					118 Corner St, Eastside
				</p>

				<div class="mt-6 border-t border-sand pt-6">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-espresso/60">
						Hours
					</p>
					<dl class="mt-3 space-y-2">
						{
							hours.map((row) => (
								<div class="flex items-baseline justify-between gap-4">
									<dt class="text-base text-espresso">{row.days}</dt>
									<dd class="text-base tabular-nums text-espresso/80">{row.time}</dd>
								</div>
							))
						}
					</dl>
					<p class="mt-3 text-sm text-espresso/60">
						Kitchen closes 30 minutes before close.
					</p>
				</div>

				<div class="mt-6 border-t border-sand pt-6">
					<p class="text-sm font-semibold uppercase tracking-[0.15em] text-espresso/60">
						Get in touch
					</p>
					<div class="mt-3 space-y-1.5">
						<p>
							<a
								href={phoneHref}
								class="text-base text-espresso transition-colors hover:text-terracotta"
							>
								{phoneDisplay}
							</a>
						</p>
						<p>
							<a
								href={`mailto:${email}`}
								class="text-base text-espresso transition-colors hover:text-terracotta"
							>
								{email}
							</a>
						</p>
					</div>
				</div>

				<div class="mt-7 flex flex-col gap-3 sm:flex-row">
					<!-- TODO: Google Maps directions URL -->
					<a
						href="#"
						class="rounded-full bg-terracotta px-6 py-3 text-center text-base font-semibold text-cream transition-colors hover:bg-terracotta/90"
					>
						Get directions
					</a>
					<a
						href={phoneHref}
						class="rounded-full border border-espresso/20 px-6 py-3 text-center text-base font-semibold text-espresso transition-colors hover:bg-cream-dark"
					>
						Call us
					</a>
				</div>
			</div>
		</div>
	</div>
</section>
