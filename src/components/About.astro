---
import { Image } from 'astro:assets';
import aboutImage from '../assets/images/about.jpg';

const stats = [
	{ value: 'Est. 2019', label: 'On the corner' },
	{ value: '12 origins', label: 'Sourced direct' },
	{ value: 'Weekly', label: 'Small-batch roast' },
];
---

<section id="about" class="bg-cream">
	<div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
		<div class="grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
			<!-- text first in DOM for mobile reading order; reordered on desktop -->
			<div class="lg:col-span-7 lg:order-last">
				<p
					class="text-sm font-semibold uppercase tracking-[0.2em] text-terracotta"
				>
					Our Story
				</p>
				<h2
					class="mt-4 max-w-xl font-display text-4xl font-semibold leading-tight tracking-tight text-espresso sm:text-5xl"
				>
					We started with one roaster and a stubborn idea.
				</h2>

				<div class="mt-6 max-w-xl space-y-4 text-lg leading-relaxed text-espresso/80">
					<p>
						Roan began in a narrow corner shop with a single drum roaster
						and the belief that coffee tastes better when you know where it
						came from. We roast in small batches, a few days a week, so the
						beans you brew are never far from the day they cracked.
					</p>
					<p>
						Over the years we’ve built real relationships with the farms we
						buy from — visiting harvests, paying above market, and letting
						each origin speak for itself. No shortcuts, no house blend hiding
						a tired bean. Just coffee we’d happily drink all day.
					</p>
				</div>

				<dl class="mt-10 grid max-w-md grid-cols-3 gap-3 border-t border-sand pt-8 sm:gap-6">
					{
						stats.map((stat) => (
							<div>
								<dt class="whitespace-nowrap font-display text-lg font-semibold text-espresso sm:text-2xl">
									{stat.value}
								</dt>
								<dd class="mt-1 text-[11px] text-espresso/70 sm:text-sm">
									{stat.label}
								</dd>
							</div>
						))
					}
				</dl>
			</div>

			<div class="relative lg:col-span-5 lg:order-first">
				<div
					class="aspect-[3/4] overflow-hidden rounded-2xl bg-cream-dark shadow-xl ring-1 ring-espresso/5"
				>
					<Image
						src={aboutImage}
						alt="A Roan barista tending the drum roaster as small-batch beans cool after a fresh roast"
						width={1000}
						widths={[500, 800, 1000]}
						sizes="(min-width: 1024px) 40vw, 90vw"
						format="webp"
						quality={80}
						class="h-full w-full object-cover"
						loading="lazy"
					/>
				</div>
				<!-- decorative block -->
				<div
					class="absolute -bottom-6 -left-6 -z-10 h-44 w-44 rounded-2xl bg-sand"
					aria-hidden="true"
				>
				</div>
			</div>
		</div>
	</div>
</section>
