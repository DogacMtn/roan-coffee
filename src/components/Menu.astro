---
const items = [
	{
		name: 'Cortado',
		description:
			'Two ristretto shots cut with a touch of steamed milk — short, balanced, velvety.',
		price: '$5',
	},
	{
		name: 'Honey Oat Latte',
		description:
			'Our house pour: espresso, creamy oat milk, and a thread of wildflower honey.',
		price: '$6',
	},
	{
		name: 'Single-Origin Pour-Over',
		description:
			'A rotating origin, brewed by hand to order. Ask the bar what we’re tasting today.',
		price: '$6',
	},
];
---

<section id="menu" class="bg-cream-dark">
	<div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
		<div class="max-w-2xl">
			<p
				class="text-sm font-semibold uppercase tracking-[0.2em] text-terracotta-text"
			>
				House Favorites
			</p>
			<h2
				class="mt-4 font-display text-4xl font-semibold leading-tight tracking-tight text-espresso sm:text-5xl"
			>
				A short list of things we love making.
			</h2>
			<p class="mt-5 text-lg leading-relaxed text-espresso/80">
				Not the whole menu — just the cups our regulars come back for.
			</p>
		</div>

		<div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
			{
				items.map((item) => (
					<article
						class="group flex flex-col rounded-2xl border border-sand bg-cream p-7 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-terracotta hover:shadow-md"
					>
						<h3 class="font-display text-2xl font-semibold text-espresso">
							{item.name}
						</h3>
						<p class="mt-3 grow text-base leading-relaxed text-espresso/80">
							{item.description}
						</p>
						<p class="mt-6 font-display text-xl font-semibold text-terracotta-text">
							{item.price}
						</p>
					</article>
				))
			}
		</div>

		<div class="mt-10">
			<a
				href="/menu"
				class="group inline-flex items-center gap-1.5 text-base font-semibold text-terracotta-text transition-colors hover:text-terracotta-text/80"
			>
				View full menu
				<span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
			</a>
		</div>
	</div>
</section>
