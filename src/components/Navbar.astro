---
const links = [
	{ label: 'Menu', href: '#menu' },
	{ label: 'About', href: '#about' },
	{ label: 'Visit', href: '#visit' },
];
---

<header
	class="sticky top-0 z-50 border-b border-sand/60 bg-cream/80 backdrop-blur-md"
>
	<nav
		class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4"
		aria-label="Main navigation"
	>
		<a
			href="#top"
			class="font-display text-2xl font-semibold tracking-tight text-espresso"
		>
			Roan
		</a>

		<div class="hidden items-center gap-8 md:flex">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="text-sm font-medium text-espresso/80 transition-colors hover:text-terracotta-text"
					>
						{link.label}
					</a>
				))
			}
			<a
				href="#order"
				class="rounded-full bg-terracotta-text px-5 py-2 text-sm font-semibold text-cream transition-colors hover:bg-terracotta-text/90"
			>
				Order Online
			</a>
		</div>

		<button
			id="nav-toggle"
			type="button"
			class="inline-flex items-center justify-center rounded-md p-2 text-espresso md:hidden"
			aria-label="Toggle menu"
			aria-controls="mobile-menu"
			aria-expanded="false"
		>
			<svg
				id="nav-icon-open"
				class="h-6 w-6"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.8"
				stroke="currentColor"
			>
				<path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
			</svg>
			<svg
				id="nav-icon-close"
				class="hidden h-6 w-6"
				fill="none"
				viewBox="0 0 24 24"
				stroke-width="1.8"
				stroke="currentColor"
			>
				<path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
			</svg>
		</button>
	</nav>

	<div id="mobile-menu" class="hidden border-t border-sand/60 bg-cream md:hidden">
		<div class="mx-auto flex max-w-6xl flex-col gap-1 px-6 py-4">
			{
				links.map((link) => (
					<a
						href={link.href}
						class="rounded-md px-2 py-3 text-base font-medium text-espresso/80 transition-colors hover:bg-cream-dark hover:text-terracotta-text"
					>
						{link.label}
					</a>
				))
			}
			<a
				href="#order"
				class="mt-2 rounded-full bg-terracotta-text px-5 py-3 text-center text-base font-semibold text-cream transition-colors hover:bg-terracotta-text/90"
			>
				Order Online
			</a>
		</div>
	</div>
</header>

<script>
	const toggle = document.getElementById('nav-toggle');
	const menu = document.getElementById('mobile-menu');
	const iconOpen = document.getElementById('nav-icon-open');
	const iconClose = document.getElementById('nav-icon-close');

	toggle?.addEventListener('click', () => {
		const isOpen = menu?.classList.toggle('hidden') === false;
		toggle.setAttribute('aria-expanded', String(isOpen));
		iconOpen?.classList.toggle('hidden', isOpen);
		iconClose?.classList.toggle('hidden', !isOpen);
	});

	// collapse after navigating
	menu?.querySelectorAll('a').forEach((link) => {
		link.addEventListener('click', () => {
			menu.classList.add('hidden');
			toggle?.setAttribute('aria-expanded', 'false');
			iconOpen?.classList.remove('hidden');
			iconClose?.classList.add('hidden');
		});
	});
</script>
