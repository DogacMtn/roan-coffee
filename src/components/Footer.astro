---
// placeholder contact details (mirrors Visit)
const phoneDisplay = '+1 (503) 555-0118';
const phoneHref = 'tel:+15035550118';
const email = 'hello@roancoffee.com';

const navLinks = [
	{ label: 'Menu', href: '#menu' },
	{ label: 'About', href: '#about' },
	{ label: 'Visit', href: '#visit' },
];

const year = new Date().getFullYear();
---

<footer class="bg-espresso text-cream">
	<div class="mx-auto max-w-6xl px-6 py-16 md:py-20">
		<div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4 lg:gap-8">
			<div>
				<a href="#top" class="font-display text-3xl font-semibold tracking-tight text-cream">
					Roan
				</a>
				<p class="mt-4 max-w-xs text-sm leading-relaxed text-cream/70">
					Small-batch coffee, roasted on the corner and poured with care.
				</p>
			</div>

			<div>
				<h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-cream/50">
					Visit
				</h2>
				<address class="mt-4 space-y-2 text-sm not-italic leading-relaxed text-cream/80">
					<p>118 Corner St, Eastside</p>
					<p>Mon–Fri 7–18 · Sat–Sun 8–17</p>
				</address>
			</div>

			<div>
				<h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-cream/50">
					Contact
				</h2>
				<ul class="mt-4 space-y-2 text-sm text-cream/80">
					<li>
						<a href={phoneHref} class="transition-colors hover:text-terracotta">
							{phoneDisplay}
						</a>
					</li>
					<li>
						<a href={`mailto:${email}`} class="transition-colors hover:text-terracotta">
							{email}
						</a>
					</li>
				</ul>
			</div>

			<div>
				<h2 class="text-sm font-semibold uppercase tracking-[0.15em] text-cream/50">
					Explore
				</h2>
				<ul class="mt-4 space-y-2 text-sm text-cream/80">
					{
						navLinks.map((link) => (
							<li>
								<a href={link.href} class="transition-colors hover:text-terracotta">
									{link.label}
								</a>
							</li>
						))
					}
				</ul>

				<!-- TODO: real social URLs -->
				<div class="mt-5 flex items-center gap-4">
					<a
						href="#"
						aria-label="Roan on Instagram"
						class="text-cream/70 transition-colors hover:text-terracotta"
					>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8">
							<rect x="2" y="2" width="20" height="20" rx="5" />
							<circle cx="12" cy="12" r="4" />
							<circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
						</svg>
					</a>
					<a
						href="#"
						aria-label="Roan on X"
						class="text-cream/70 transition-colors hover:text-terracotta"
					>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"
							></path>
						</svg>
					</a>
					<a
						href="#"
						aria-label="Roan on Facebook"
						class="text-cream/70 transition-colors hover:text-terracotta"
					>
						<svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
							<path
								d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
							></path>
						</svg>
					</a>
				</div>
			</div>
		</div>

		<div
			class="mt-12 flex flex-col gap-3 border-t border-cream/15 pt-6 text-sm text-cream/40 sm:flex-row sm:items-center sm:justify-between"
		>
			<p>© {year} Roan Coffee Roasters. All rights reserved.</p>
			<div class="flex gap-5">
				<a href="#" class="transition-colors hover:text-terracotta">Privacy</a>
				<a href="#" class="transition-colors hover:text-terracotta">Terms</a>
			</div>
		</div>
	</div>
</footer>
